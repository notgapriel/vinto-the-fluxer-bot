{
  "name": "fluxer-music-bot",
  "version": "0.6.1",
  "description": "Production-minded music bot for Fluxer with resilient playback, persistence, and monitoring.",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "pnpm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/src/index.js",
    "dev": "node --import tsx --watch src/index.ts",
    "test": "node scripts/run-tests.mjs",
    "spotify:token": "node --import tsx scripts/get-spotify-refresh-token.ts"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "bot",
    "music",
    "fluxer",
    "livekit",
    "mongodb",
    "youtube",
    "soundcloud",
    "spotify",
    "deezer"
  ],
  "dependencies": {
    "@livekit/rtc-node": "^0.13.25",
    "@sentry/node": "^10.43.0",
    "dotenv": "^17.3.1",
    "egoroof-blowfish": "^4.0.2",
    "ffmpeg-static": "^5.3.0",
    "mongodb": "^7.1.0",
    "play-dl": "^1.9.7",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.20.5",
    "typescript": "^6.0.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "ffmpeg-static"
    ]
  }
}
