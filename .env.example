BOT_TOKEN=your_bot_token_here
PREFIX=!

API_BASE=https://api.fluxer.app/v1
GATEWAY_URL=wss://gateway.fluxer.app
DNS_RESULT_ORDER=ipv4first
AUTO_GATEWAY_URL=1
GATEWAY_ONLY_MODE=0

LOG_LEVEL=info
ENABLE_EMBEDS=1
ALLOW_DEFAULT_PREFIX_FALLBACK=0

COMMAND_RATE_LIMIT_ENABLED=1
COMMAND_USER_WINDOW_MS=10000
COMMAND_USER_MAX=8
COMMAND_GUILD_WINDOW_MS=10000
COMMAND_GUILD_MAX=40
COMMAND_RATE_LIMIT_BYPASS=help,ping

MONITORING_ENABLED=1
MONITORING_HOST=0.0.0.0
MONITORING_PORT=9091
# Optional
# SENTRY_DSN=
SENTRY_ENVIRONMENT=production

MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=fluxer_music_bot
MONGODB_MAX_POOL_SIZE=120
MONGODB_MIN_POOL_SIZE=5
MONGODB_CONNECT_TIMEOUT_MS=10000
MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
GUILD_CONFIG_CACHE_TTL_MS=60000
GUILD_CONFIG_CACHE_MAX_SIZE=5000

# Optional media provider auth for direct Spotify/SoundCloud URL support
# Spotify needs all three values:
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REFRESH_TOKEN=
SPOTIFY_MARKET=US
# Optional helper vars for `npm run spotify:token`
SPOTIFY_REDIRECT_URI=http://127.0.0.1:9876/spotify/callback
SPOTIFY_SCOPE=user-read-email
SPOTIFY_ALLOW_MISSING_STATE=1
# SoundCloud: set explicit client id or let bot auto-fetch one on startup
# SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_AUTO_CLIENT_ID=1
STRICT_MEDIA_AUTH=0

STRICT_STARTUP_CHECK=0
API_CHECK_RETRIES=5
API_CHECK_DELAY_MS=1000

REST_TIMEOUT_MS=10000
REST_MAX_RETRIES=4
REST_RETRY_BASE_DELAY_MS=300

SESSION_IDLE_MS=300000
MAX_QUEUE_SIZE=100
MAX_PLAYLIST_TRACKS=25
MAX_SAVED_PLAYLISTS_PER_GUILD=100
MAX_SAVED_TRACKS_PER_PLAYLIST=500
MAX_FAVORITES_PER_USER=500
PERSISTENT_HISTORY_SIZE=200
PLAY_COMMAND_COOLDOWN_MS=2000
SEARCH_RESULT_LIMIT=5
SEARCH_PICK_TIMEOUT_MS=45000
DEFAULT_AUTOPLAY_ENABLED=0
DEFAULT_DEDUPE_ENABLED=0
DEFAULT_247_ENABLED=0
VOTE_SKIP_RATIO=0.5
VOTE_SKIP_MIN_VOTES=2
ENABLE_YT_SEARCH=1
ENABLE_YT_PLAYBACK=1
ENABLE_SPOTIFY_IMPORT=1
ENABLE_DEEZER_IMPORT=1

DEFAULT_VOLUME_PERCENT=100
MIN_VOLUME_PERCENT=0
MAX_VOLUME_PERCENT=200

# Optional binary overrides
# FFMPEG_BIN=/usr/bin/ffmpeg
# YTDLP_BIN=/usr/bin/yt-dlp

# Optional yt-dlp hardening for YouTube bot-checks
# Export a cookies.txt file (Netscape format) and point to it:
# YTDLP_COOKIES_FILE=/absolute/path/to/cookies.txt
# Or let yt-dlp read cookies directly from your browser profile:
# YTDLP_COOKIES_FROM_BROWSER=firefox
# Optional YouTube client profile for extractor.
# Leave this unset for automatic yt-dlp client selection (most stable default).
# YTDLP_YOUTUBE_CLIENT=ios,android,web
# Optional extra args (comma-separated, each entry becomes one arg).
# Keep this unset unless you need a specific workaround.
# YTDLP_EXTRA_ARGS=--geo-bypass,--force-ipv4
